# Runtime configurations
ALPHATRION_LOG_LEVEL=INFO

# Database configurations
ALPHATRION_METADATA_DB_URL=postgresql+psycopg2://alphatrion:alphatr1on@localhost:5432/alphatrion

# Artifact storage configurations
ALPHATRION_ENABLE_ARTIFACT_STORAGE=true
# Storage type: "oci" (default) or "s3"
ALPHATRION_ARTIFACT_STORAGE_TYPE=oci

# OCI Registry configuration (used when ARTIFACT_STORAGE_TYPE=oci)
ALPHATRION_ARTIFACT_REGISTRY_URL=localhost:5001
ALPHATRION_ARTIFACT_INSECURE=false

# S3 configuration (used when ARTIFACT_STORAGE_TYPE=s3)
# ALPHATRION_ARTIFACT_S3_BUCKET=my-artifacts-bucket
# ALPHATRION_ARTIFACT_S3_ENDPOINT=https://s3.amazonaws.com  # Optional, for S3-compatible services
# ALPHATRION_ARTIFACT_S3_ACCESS_KEY=your-access-key
# ALPHATRION_ARTIFACT_S3_SECRET_KEY=your-secret-key
# ALPHATRION_ARTIFACT_S3_REGION=us-east-1  # Default: us-east-1

# Tracing configurations
ALPHATRION_ENABLE_TRACING=true
ALPHATRION_CLICKHOUSE_ENABLE_BATCH=true

# Prometheus push gateway configurations
ALPHATRION_ENABLE_PROMETHEUS_EXPORTER=false
ALPHATRION_PROMETHEUS_PUSHGATEWAY_URL=localhost:9091
ALPHATRION_PROMETHEUS_JOB_NAME=alphatrion

# Authentication configurations
# Set to true to enable JWT authentication, false to use direct headers (x-user-id, x-org-id)
ALPHATRION_ENABLE_AUTH=true
ALPHATRION_JWT_SECRET=your_jwt_secret_key_here
