  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Platform Tokens",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(llm_tokens_total{token_type=\"total\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      }
    },
    {
      "title": "Total Platform Requests",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(llm_requests_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(llm_requests_total{status=\"ERROR\"}[5m])) / sum(rate(llm_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      }
    },
    {
      "title": "Total Platform Cost",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(llm_cost_total{cost_type=\"total\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "auto"
      }
    },
    {
      "title": "Errors by Type",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (error_type) (llm_errors_total)",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "pieType": "pie"
      }
    },
    {
      "title": "Active Experiments (Time Window)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "count(sum by (experiment_id) (increase(llm_requests_total[5m])) > 0)",
          "legendFormat": "Active Experiments",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "description": "Number of unique experiments with activity in the last 5 minutes. Drops to 0 when experiments finish."
    },
    {
      "title": "Active Teams (Time Window)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 5
      },
      "targets": [
        {
          "expr": "count(sum by (team_id) (increase(llm_requests_total[5m])) > 0)",
          "legendFormat": "Active Teams",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "description": "Number of unique teams with activity in the last 5 minutes. Drops when teams stop running experiments."
    },
    {
      "title": "Token Usage (Platform-wide, Cumulative)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 14,
        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "expr": "sum(llm_tokens_total{token_type=\"input\"})",
          "legendFormat": "Input Tokens",
          "refId": "A"
        },
        {
          "expr": "sum(llm_tokens_total{token_type=\"output\"})",
          "legendFormat": "Output Tokens",
          "refId": "B"
        },
        {
          "expr": "sum(llm_tokens_total{token_type=\"cache_read_input\"})",
          "legendFormat": "Cache Read Input Tokens",
          "refId": "C"
        },
        {
          "expr": "sum(llm_tokens_total{token_type=\"cache_creation_input\"})",
          "legendFormat": "Cache Creation Input Tokens",
          "refId": "D"
        },
        {
          "expr": "sum(llm_tokens_total{token_type=\"total\"})",
          "legendFormat": "Total Tokens",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Input Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Output Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cache Read Input Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cache Creation Input Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Tokens"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 3
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "description": "Accumulated tokens across ALL teams and experiments. Total = Input + Output + Cache tokens. Should keep growing as you run more experiments."
    },
