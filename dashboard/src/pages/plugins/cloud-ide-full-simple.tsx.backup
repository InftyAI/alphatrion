/**
 * Complete Cloud IDE - Full-featured development environment
 *
 * Integrated from the forked project's trial detail IDE, adapted for:
 * - Experiment-based workflow (team -> project -> experiment -> run)
 * - Both local workspace and K8s sandbox modes
 * - File browser, code editor, terminal, chat, and content evolution
 */

import { useState, useEffect, useCallback, useRef } from 'react';
import { useParams, useSearchParams } from 'react-router-dom';
import {
  Code,
  FileText,
  Terminal as TerminalIcon,
  MessageSquare,
  Play,
  Save,
  RefreshCw,
  Maximize2,
  Minimize2,
  FolderTree,
  Settings,
} from 'lucide-react';
import { Card, CardContent, CardHeader, CardTitle } from '../../components/ui/card';
import { Button } from '../../components/ui/button';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '../../components/ui/tabs';
import { Badge } from '../../components/ui/badge';

// Import IDE components
import { FileTree } from '../../components/ide/repo/file-tree-simple';
import { MonacoCodeEditor } from '../../components/ide/editor/monaco-code-editor';
import { TerminalPanel } from '../../components/ide/terminal/terminal-panel-simple';
import { ChatPanel } from '../../components/ide/chat/chat-simple';

type WorkspaceMode = 'local' | 'k8s';

interface FileNode {
  name: string;
  path: string;
  type: 'file' | 'directory';
  size?: number;
  modified?: number;
  children?: FileNode[];
}

export function CloudIDEFull() {
  const { experimentId } = useParams<{ experimentId?: string }>();
  const [searchParams] = useSearchParams();
  const podName = searchParams.get('pod');

  // Determine mode based on pod parameter
  const mode: WorkspaceMode = podName ? 'k8s' : 'local';

  // File system state
  const [fileTree, setFileTree] = useState<FileNode | null>(null);
  const [selectedFile, setSelectedFile] = useState<string | null>(null);
  const [fileContent, setFileContent] = useState<string>('');
  const [originalContent, setOriginalContent] = useState<string>('');
  const [isModified, setIsModified] = useState(false);

  // Panel visibility
  const [showFileBrowser, setShowFileBrowser] = useState(true);
  const [showTerminal, setShowTerminal] = useState(true);
  const [showChat, setShowChat] = useState(false);

  // Panel ratios for resizable layout
  const [fileBrowserWidth, setFileBrowserWidth] = useState(250); // px
  const [terminalHeight, setTerminalHeight] = useState(200); // px

  // Terminal state
  const [terminalOutput, setTerminalOutput] = useState<string>('');
  const [terminalCommand, setTerminalCommand] = useState<string>('');

  // Load file tree
  const loadFileTree = useCallback(async () => {
    try {
      const endpoint = mode === 'k8s'
        ? `/api/plugins/cloud-ide/k8s/pods/${podName}/files/list?path=/workspace`
        : '/api/plugins/cloud-ide/files/tree';

      const response = await fetch(endpoint);
      const data = await response.json();

      if (mode === 'k8s') {
        // Convert K8s file list to tree structure
        const tree: FileNode = {
          name: 'workspace',
          path: '',
          type: 'directory',
          children: data.files || [],
        };
        setFileTree(tree);
      } else {
        setFileTree(data);
      }
    } catch (error) {
      console.error('Failed to load file tree:', error);
    }
  }, [mode, podName]);

  // Load file content
  const loadFile = useCallback(async (path: string) => {
    try {
      const endpoint = mode === 'k8s'
        ? `/api/plugins/cloud-ide/k8s/pods/${podName}/files/read`
        : `/api/plugins/cloud-ide/files/content?path=${encodeURIComponent(path)}`;

      const response = await fetch(endpoint, {
        method: mode === 'k8s' ? 'POST' : 'GET',
        headers: mode === 'k8s' ? { 'Content-Type': 'application/json' } : undefined,
        body: mode === 'k8s' ? JSON.stringify({ path }) : undefined,
      });

      const data = await response.json();
      const content = data.content;

      setFileContent(content);
      setOriginalContent(content);
      setSelectedFile(path);
      setIsModified(false);
    } catch (error) {
      console.error('Failed to load file:', error);
    }
  }, [mode, podName]);

  // Save file
  const saveFile = useCallback(async () => {
    if (!selectedFile) return;

    try {
      const endpoint = mode === 'k8s'
        ? `/api/plugins/cloud-ide/k8s/pods/${podName}/files/write`
        : '/api/plugins/cloud-ide/files/save';

      await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(
          mode === 'k8s'
            ? { path: selectedFile, content: fileContent }
            : { path: selectedFile, content: fileContent }
        ),
      });

      setOriginalContent(fileContent);
      setIsModified(false);
      alert('File saved successfully');
    } catch (error) {
      console.error('Failed to save file:', error);
      alert('Failed to save file');
    }
  }, [selectedFile, fileContent, mode, podName]);

  // Execute terminal command
  const executeCommand = useCallback(async () => {
    if (!terminalCommand.trim()) return;

    setTerminalOutput((prev) => `${prev}$ ${terminalCommand}\n`);

    try {
      const endpoint = mode === 'k8s'
        ? `/api/plugins/cloud-ide/k8s/pods/${podName}/terminal/execute`
        : '/api/plugins/cloud-ide/terminal/execute';

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ command: terminalCommand }),
      });

      const data = await response.json();
      setTerminalOutput(
        (prev) => `${prev}${data.stdout}${data.stderr ? `\n${data.stderr}` : ''}\n`
      );
      setTerminalCommand('');
    } catch (error) {
      setTerminalOutput((prev) => `${prev}Error: ${error}\n`);
    }
  }, [terminalCommand, mode, podName]);

  // Load file tree on mount
  useEffect(() => {
    loadFileTree();
  }, [loadFileTree]);

  // Track file modifications
  useEffect(() => {
    setIsModified(fileContent !== originalContent);
  }, [fileContent, originalContent]);

  // Keyboard shortcuts
  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      // Cmd/Ctrl + S to save
      if ((e.metaKey || e.ctrlKey) && e.key === 's') {
        e.preventDefault();
        if (isModified) {
          saveFile();
        }
      }
    };

    document.addEventListener('keydown', handleKeyDown);
    return () => document.removeEventListener('keydown', handleKeyDown);
  }, [isModified, saveFile]);

  return (
    <div className="flex flex-col h-screen bg-background">
      {/* Top Bar */}
      <div className="flex items-center justify-between h-14 px-4 border-b bg-card">
        <div className="flex items-center gap-4">
          <h1 className="text-lg font-semibold flex items-center gap-2">
            <Code className="h-5 w-5" />
            Cloud IDE
          </h1>
          <Badge variant={mode === 'k8s' ? 'default' : 'secondary'}>
            {mode === 'k8s' ? `Pod: ${podName}` : 'Local Workspace'}
          </Badge>
        </div>

        <div className="flex items-center gap-2">
          <Button
            variant="ghost"
            size="sm"
            onClick={() => setShowFileBrowser(!showFileBrowser)}
            title="Toggle file browser"
          >
            <FolderTree className="h-4 w-4" />
          </Button>
          <Button
            variant="ghost"
            size="sm"
            onClick={() => setShowTerminal(!showTerminal)}
            title="Toggle terminal"
          >
            <TerminalIcon className="h-4 w-4" />
          </Button>
          <Button
            variant="ghost"
            size="sm"
            onClick={() => setShowChat(!showChat)}
            title="Toggle chat"
          >
            <MessageSquare className="h-4 w-4" />
          </Button>
          <div className="w-px h-6 bg-border mx-2" />
          <Button
            variant="ghost"
            size="sm"
            onClick={loadFileTree}
            title="Refresh"
          >
            <RefreshCw className="h-4 w-4" />
          </Button>
          <Button
            variant="ghost"
            size="sm"
            onClick={saveFile}
            disabled={!isModified}
            title="Save (Cmd+S)"
          >
            <Save className="h-4 w-4" />
          </Button>
        </div>
      </div>

      {/* Main Content Area */}
      <div className="flex flex-1 overflow-hidden">
        {/* File Browser */}
        {showFileBrowser && (
          <div
            className="border-r bg-card overflow-y-auto"
            style={{ width: fileBrowserWidth }}
          >
            <div className="p-2">
              <h3 className="text-sm font-semibold mb-2">Files</h3>
              {fileTree && (
                <FileTree
                  node={fileTree}
                  onFileSelect={loadFile}
                  selectedPath={selectedFile}
                />
              )}
            </div>
          </div>
        )}

        {/* Editor Area */}
        <div className="flex-1 flex flex-col overflow-hidden">
          {/* Editor */}
          <div className="flex-1 overflow-hidden">
            {selectedFile ? (
              <div className="h-full flex flex-col">
                <div className="flex items-center justify-between px-4 py-2 border-b bg-muted/30">
                  <span className="text-sm font-medium">{selectedFile}</span>
                  {isModified && (
                    <Badge variant="outline" className="text-xs">
                      Modified
                    </Badge>
                  )}
                </div>
                <div className="flex-1">
                  <MonacoCodeEditor
                    value={fileContent}
                    onChange={setFileContent}
                    language={getLanguageFromFilename(selectedFile)}
                    readOnly={false}
                  />
                </div>
              </div>
            ) : (
              <div className="flex items-center justify-center h-full text-muted-foreground">
                <div className="text-center">
                  <FileText className="h-12 w-12 mx-auto mb-2 opacity-50" />
                  <p>Select a file to edit</p>
                </div>
              </div>
            )}
          </div>

          {/* Terminal Panel */}
          {showTerminal && (
            <div
              className="border-t bg-card"
              style={{ height: terminalHeight }}
            >
              <TerminalPanel
                output={terminalOutput}
                command={terminalCommand}
                onCommandChange={setTerminalCommand}
                onExecute={executeCommand}
                podName={mode === 'k8s' ? podName || undefined : undefined}
              />
            </div>
          )}
        </div>

        {/* Chat Panel */}
        {showChat && (
          <div className="w-80 border-l bg-card overflow-y-auto">
            <div className="p-4">
              <h3 className="text-sm font-semibold mb-3">AI Assistant</h3>
              <ChatPanel
                experimentId={experimentId}
                context={{
                  mode,
                  selectedFile,
                  fileContent: selectedFile ? fileContent : undefined,
                }}
              />
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

// Helper function to determine language from filename
function getLanguageFromFilename(filename: string): string {
  const ext = filename.split('.').pop()?.toLowerCase();
  const languageMap: Record<string, string> = {
    js: 'javascript',
    jsx: 'javascript',
    ts: 'typescript',
    tsx: 'typescript',
    py: 'python',
    java: 'java',
    cpp: 'cpp',
    c: 'c',
    h: 'cpp',
    hpp: 'cpp',
    go: 'go',
    rs: 'rust',
    rb: 'ruby',
    php: 'php',
    html: 'html',
    css: 'css',
    scss: 'scss',
    json: 'json',
    yaml: 'yaml',
    yml: 'yaml',
    xml: 'xml',
    md: 'markdown',
    sql: 'sql',
    sh: 'shell',
    bash: 'shell',
  };

  return languageMap[ext || ''] || 'plaintext';
}
